# mihi smoke test — proves the library compiles end-to-end and the
# stdlib include chain resolves. CI builds this to confirm no
# regression in the dist bundle.
#
# Build: cyrius build programs/smoke.cyr build/mihi-smoke
# Run:   ./build/mihi-smoke   (exit 0 on success)

include "src/main.cyr"

fn main() {
    alloc_init();
    println("mihi smoke ok");
    return 0;
}

var r = main();
syscall(SYS_EXIT, r);
