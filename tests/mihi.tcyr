# mihi test suite — slice A (uname-backed probes).
#
# Strategy mirrors darshana: bytewise/buffer logic is exercised
# directly with synthetic uts buffers (no real uname call), and one
# happy-path test goes through the real syscall to prove the wrapper
# wires up. Stdlib auto-included via cyrius.cyml.

include "src/main.cyr"

fn main() {
    alloc_init();

    test_group("smoke");
    assert(1, "true is true");
    assert_eq(1 + 1, 2, "math works");

    # ----- mihi_uname — happy path -----------------------------------
    # Real syscall on whatever box runs CI. Should land Ok(buf).
    test_group("kernel.cyr — mihi_uname happy path");
    var uts[390];
    var i = 0;
    while (i < 390) { store8(&uts + i, 0); i = i + 1; }
    var res = mihi_uname(&uts);
    assert_eq(is_err_result(res), 0, "uname(2) returns Ok on linux");

    # Sysname is always populated on a real kernel; first byte is non-null.
    # On Linux, sysname starts with 'L' (0x4C).
    assert_eq(load8(&uts + UTS_SYSNAME), 76, "sysname[0] == 'L' (Linux)");

    # ----- mihi_kernel_name — field-offset accessor ------------------
    # Pure pointer arithmetic; verify the returned pointer matches
    # uts + UTS_SYSNAME by reading the first byte through both paths.
    test_group("kernel.cyr — mihi_kernel_name field accessor");
    var name_ptr = mihi_kernel_name(&uts);
    assert_eq(load8(name_ptr), load8(&uts + UTS_SYSNAME),
              "mihi_kernel_name points at uts.sysname");

    # ----- mihi_kernel_name — error path / synthetic buffer ----------
    # Field accessor is pure pointer math — it doesn't validate that
    # uname(2) succeeded. Caller is responsible for checking the
    # mihi_uname Result. Verify that on a zero-init buffer, the
    # accessor still returns the same offset (a null string in that
    # field); this documents the "uts must be populated first" contract.
    test_group("kernel.cyr — mihi_kernel_name on zero-init uts");
    var zuts[390];
    var z = 0;
    while (z < 390) { store8(&zuts + z, 0); z = z + 1; }
    var zname = mihi_kernel_name(&zuts);
    assert_eq(load8(zname), 0, "zero-init uts → empty sysname");

    # ----- mihi_kernel_version — field accessor + offset ------------
    test_group("kernel.cyr — mihi_kernel_version field accessor");
    var rel_ptr = mihi_kernel_version(&uts);
    assert_eq(load8(rel_ptr), load8(&uts + UTS_RELEASE),
              "mihi_kernel_version points at uts.release");
    # Release is non-empty on a real kernel.
    assert(load8(rel_ptr) != 0, "release[0] is non-null on linux");

    # ----- mihi_cpu_arch — field accessor + offset -------------------
    test_group("cpu.cyr — mihi_cpu_arch field accessor");
    var arch_ptr = mihi_cpu_arch(&uts);
    assert_eq(load8(arch_ptr), load8(&uts + UTS_MACHINE),
              "mihi_cpu_arch points at uts.machine");
    # Arch is non-empty on a real kernel.
    assert(load8(arch_ptr) != 0, "machine[0] is non-null on linux");

    # ----- synthetic uts — verify offsets are stable -----------------
    # Write known sentinels into each field; confirm each accessor
    # reads the matching sentinel back. No syscall involved.
    test_group("uts offsets — synthetic buffer round-trip");
    var suts[390];
    var s = 0;
    while (s < 390) { store8(&suts + s, 0); s = s + 1; }
    store8(&suts + UTS_SYSNAME,  65);  # 'A'
    store8(&suts + UTS_RELEASE,  66);  # 'B'
    store8(&suts + UTS_MACHINE,  67);  # 'C'
    assert_eq(load8(mihi_kernel_name(&suts)),    65, "sysname offset stable");
    assert_eq(load8(mihi_kernel_version(&suts)), 66, "release offset stable");
    assert_eq(load8(mihi_cpu_arch(&suts)),       67, "machine offset stable");

    # ----- cpu.cyr — mihi_parse_cpu_range ---------------------------
    # Pure-function parser; no syscall. Build small synthetic buffers
    # for each shape /sys/devices/system/cpu/online actually emits.

    test_group("cpu.cyr — mihi_parse_cpu_range shapes");

    # "0-15" → 16
    var r1[8];
    store8(&r1 + 0, 48); store8(&r1 + 1, 45);
    store8(&r1 + 2, 49); store8(&r1 + 3, 53);
    assert_eq(mihi_parse_cpu_range(&r1, 4), 16, "range '0-15' = 16 CPUs");

    # "0" → 1
    var r2[4];
    store8(&r2 + 0, 48);
    assert_eq(mihi_parse_cpu_range(&r2, 1), 1, "range '0' = 1 CPU");

    # "0-15\n" — trailing newline shouldn't break us
    var r3[8];
    store8(&r3 + 0, 48); store8(&r3 + 1, 45);
    store8(&r3 + 2, 49); store8(&r3 + 3, 53);
    store8(&r3 + 4, 10);
    assert_eq(mihi_parse_cpu_range(&r3, 5), 16, "trailing \\n tolerated");

    # "0-3,5-7" → 4 + 3 = 7 (disjoint range)
    var r4[16];
    store8(&r4 + 0, 48); store8(&r4 + 1, 45); store8(&r4 + 2, 51);
    store8(&r4 + 3, 44);
    store8(&r4 + 4, 53); store8(&r4 + 5, 45); store8(&r4 + 6, 55);
    assert_eq(mihi_parse_cpu_range(&r4, 7), 7, "disjoint ranges sum");

    # Empty buffer → 0
    var r5[4];
    assert_eq(mihi_parse_cpu_range(&r5, 0), 0, "empty buffer = 0");

    # ----- cpu.cyr — mihi_cpu_count happy path ----------------------
    # Real /sys read; should be >= 1 on any Linux box.
    test_group("cpu.cyr — mihi_cpu_count happy path");
    var live_ncpu: i64 = mihi_cpu_count();
    assert(live_ncpu >= 1, "at least one logical CPU online");

    # ----- cpu.cyr — mihi_parse_cpu_model ---------------------------
    # Synthetic cpuinfo. Layout matches real /proc/cpuinfo: first line
    # is "processor\t: 0\n", second is "model name\t: <brand>\n". The
    # parser searches for "\nmodel name" so the leading 'processor'
    # line is required for the match.

    test_group("cpu.cyr — mihi_parse_cpu_model happy path");
    var ci1 = "processor\t: 0\nmodel name\t: TestCPU\nfoo\n";
    var ci1_buf[128];
    var ci1_len: i64 = strlen(ci1);
    var ci1_i = 0;
    while (ci1_i < ci1_len) {
        store8(&ci1_buf + ci1_i, load8(ci1 + ci1_i));
        ci1_i = ci1_i + 1;
    }
    var model1 = mihi_parse_cpu_model(&ci1_buf, ci1_len);
    assert(model1 != 0, "model found in well-formed cpuinfo");
    assert_eq(streq(model1, "TestCPU"), 1, "model value == 'TestCPU'");

    # No "model name" line → returns null.
    test_group("cpu.cyr — mihi_parse_cpu_model missing field");
    var ci2 = "processor\t: 0\nstepping\t: 1\n";
    var ci2_buf[64];
    var ci2_len: i64 = strlen(ci2);
    var ci2_i = 0;
    while (ci2_i < ci2_len) {
        store8(&ci2_buf + ci2_i, load8(ci2 + ci2_i));
        ci2_i = ci2_i + 1;
    }
    var model2 = mihi_parse_cpu_model(&ci2_buf, ci2_len);
    assert_eq(model2, 0, "missing 'model name' → null");

    # "model name" at file-start (no leading '\n') should NOT match —
    # documents the "preceded-by-newline" line-anchor contract.
    test_group("cpu.cyr — mihi_parse_cpu_model line-anchor");
    var ci3 = "model name\t: SneakyImposter\n";
    var ci3_buf[64];
    var ci3_len: i64 = strlen(ci3);
    var ci3_i = 0;
    while (ci3_i < ci3_len) {
        store8(&ci3_buf + ci3_i, load8(ci3 + ci3_i));
        ci3_i = ci3_i + 1;
    }
    var model3 = mihi_parse_cpu_model(&ci3_buf, ci3_len);
    assert_eq(model3, 0, "file-start 'model name' rejected (line-anchored)");

    # ----- cpu.cyr — mihi_cpu_model happy path ----------------------
    test_group("cpu.cyr — mihi_cpu_model real /proc/cpuinfo");
    var live_buf[8192];
    var live_model = mihi_cpu_model(&live_buf, 8192);
    assert(live_model != 0, "live /proc/cpuinfo yields a model");
    assert(strlen(live_model) > 0, "live model string is non-empty");

    # ----- mem.cyr — mihi_find_meminfo_field line-anchor -----------
    # Real meminfo has MemTotal at file-start (no leading '\n');
    # MemAvailable is mid-buffer (preceded by '\n'). Verify the
    # anchor accepts both shapes and rejects mid-line "MemTotal:".

    test_group("mem.cyr — find_meminfo_field anchors");
    var mi1 = "MemTotal:       100 kB\nMemFree:         50 kB\nMemAvailable:    80 kB\n";
    var mi1_buf[128];
    var mi1_len: i64 = strlen(mi1);
    var mi1_i = 0;
    while (mi1_i < mi1_len) {
        store8(&mi1_buf + mi1_i, load8(mi1 + mi1_i));
        mi1_i = mi1_i + 1;
    }

    var pos_total: i64 = mihi_find_meminfo_field(&mi1_buf, mi1_len, "MemTotal:", 9);
    var pos_avail: i64 = mihi_find_meminfo_field(&mi1_buf, mi1_len, "MemAvailable:", 13);
    var pos_free: i64 = mihi_find_meminfo_field(&mi1_buf, mi1_len, "MemFree:", 8);
    assert_eq(pos_total, 9,  "MemTotal at file-start matched (past colon)");
    assert(pos_avail > pos_free, "MemAvailable found after MemFree");
    assert(pos_free > pos_total,  "MemFree found after MemTotal");

    # Mid-line match must be rejected — e.g. "XMemTotal:" should
    # not match if the leading 'X' is not '\n'.
    var mi2 = "XMemTotal: 1 kB\n";
    var mi2_buf[32];
    var mi2_len: i64 = strlen(mi2);
    var mi2_i = 0;
    while (mi2_i < mi2_len) {
        store8(&mi2_buf + mi2_i, load8(mi2 + mi2_i));
        mi2_i = mi2_i + 1;
    }
    var pos_bad: i64 = mihi_find_meminfo_field(&mi2_buf, mi2_len, "MemTotal:", 9);
    assert_eq(pos_bad, 0 - 1, "mid-line 'MemTotal:' rejected");

    # ----- mem.cyr — mihi_parse_meminfo_kb digit parsing -----------
    test_group("mem.cyr — parse_meminfo_kb");
    # Same mi1_buf as above. Past MemTotal: colon at offset 9.
    var kb_total: i64 = mihi_parse_meminfo_kb(&mi1_buf, mi1_len, pos_total);
    assert_eq(kb_total, 100, "MemTotal parsed as 100 kB");
    var kb_avail: i64 = mihi_parse_meminfo_kb(&mi1_buf, mi1_len, pos_avail);
    assert_eq(kb_avail, 80,  "MemAvailable parsed as 80 kB");

    # ----- mem.cyr — mihi_extract_meminfo_bytes end-to-end ---------
    test_group("mem.cyr — extract_meminfo_bytes kB→bytes");
    var bytes_total: i64 = mihi_extract_meminfo_bytes(&mi1_buf, mi1_len, "MemTotal:", 9);
    assert_eq(bytes_total, 102400, "100 kB → 102400 bytes");
    var bytes_missing: i64 = mihi_extract_meminfo_bytes(&mi1_buf, mi1_len, "Swap:", 5);
    assert_eq(bytes_missing, 0 - 1, "missing field → -1");

    # ----- mem.cyr — mihi_mem_total / mihi_mem_free happy paths ----
    test_group("mem.cyr — mihi_mem_total real /proc/meminfo");
    var mem_buf[4096];
    var live_total: i64 = mihi_mem_total(&mem_buf, 4096);
    assert(live_total > 0, "live MemTotal > 0 bytes");
    # Sanity floor: any modern Linux box has at least 128 MiB.
    assert(live_total >= 134217728, "live MemTotal >= 128 MiB");

    test_group("mem.cyr — mihi_mem_free real /proc/meminfo");
    var live_free: i64 = mihi_mem_free(&mem_buf, 4096);
    assert(live_free > 0, "live MemAvailable > 0 bytes");
    assert(live_free <= live_total, "MemAvailable <= MemTotal");

    # ----- host.cyr — mihi_hostname uts.nodename accessor -----------
    # Shares the uts buffer with the kernel/cpu probes (ADR 0001).
    # Field offset for nodename is 65; verify the accessor returns
    # that exact pointer via a sentinel round-trip on a synthetic uts.
    test_group("host.cyr — mihi_hostname uts.nodename accessor");
    var huts[390];
    var hi = 0;
    while (hi < 390) { store8(&huts + hi, 0); hi = hi + 1; }
    store8(&huts + UTS_NODENAME, 72);  # 'H'
    var hn = mihi_hostname(&huts);
    assert_eq(load8(hn), 72, "mihi_hostname reads synthetic 'H' from nodename slot");

    # Real uname: any Linux box has a non-empty nodename ("(none)" on
    # boxes without sethostname is still non-null first byte).
    test_group("host.cyr — mihi_hostname real uname");
    var luts[390];
    var li = 0;
    while (li < 390) { store8(&luts + li, 0); li = li + 1; }
    var hres = mihi_uname(&luts);
    assert_eq(is_err_result(hres), 0, "uname(2) Ok for hostname probe");
    var live_hn = mihi_hostname(&luts);
    assert(load8(live_hn) != 0, "live nodename first byte non-null");

    # ----- host.cyr — mihi_parse_uptime_secs ------------------------
    # Pure parser. Accepts the "%lu.%02lu" prefix the kernel writes;
    # drops the fractional part. Rejects empty / no-leading-digit.
    test_group("host.cyr — mihi_parse_uptime_secs shapes");

    # "12345.67 13611.75\n" → 12345
    var u1 = "12345.67 13611.75\n";
    var u1_buf[32];
    var u1_len: i64 = strlen(u1);
    var u1_i = 0;
    while (u1_i < u1_len) {
        store8(&u1_buf + u1_i, load8(u1 + u1_i));
        u1_i = u1_i + 1;
    }
    assert_eq(mihi_parse_uptime_secs(&u1_buf, u1_len), 12345,
              "'12345.67 …' → 12345 secs (fractional dropped)");

    # "0.50 0.10\n" → 0 (valid; box just booted)
    var u2 = "0.50 0.10\n";
    var u2_buf[16];
    var u2_len: i64 = strlen(u2);
    var u2_i = 0;
    while (u2_i < u2_len) {
        store8(&u2_buf + u2_i, load8(u2 + u2_i));
        u2_i = u2_i + 1;
    }
    assert_eq(mihi_parse_uptime_secs(&u2_buf, u2_len), 0,
              "'0.50 …' → 0 secs (freshly booted)");

    # Empty buffer → -1
    var u3[4];
    assert_eq(mihi_parse_uptime_secs(&u3, 0), 0 - 1,
              "empty buffer → -1");

    # Leading non-digit → -1
    var u4 = "abc";
    var u4_buf[8];
    store8(&u4_buf + 0, load8(u4 + 0));
    store8(&u4_buf + 1, load8(u4 + 1));
    store8(&u4_buf + 2, load8(u4 + 2));
    assert_eq(mihi_parse_uptime_secs(&u4_buf, 3), 0 - 1,
              "leading non-digit → -1");

    # ----- host.cyr — mihi_uptime_secs real /proc/uptime ------------
    test_group("host.cyr — mihi_uptime_secs real /proc/uptime");
    var up_buf[64];
    var live_up: i64 = mihi_uptime_secs(&up_buf, 64);
    assert(live_up >= 0, "live /proc/uptime parsed (>= 0 secs)");

    # ----- host.cyr — mihi_find_osrelease_key anchors --------------
    # Same line-anchor contract as meminfo: file-start or '\n'-prefix.
    # Mid-line "PRETTY_NAME=" must be rejected.
    test_group("host.cyr — find_osrelease_key anchors");
    var or1 = "NAME=\"Arch Linux\"\nPRETTY_NAME=\"Arch Linux\"\nID=arch\n";
    var or1_buf[128];
    var or1_len: i64 = strlen(or1);
    var or1_i = 0;
    while (or1_i < or1_len) {
        store8(&or1_buf + or1_i, load8(or1 + or1_i));
        or1_i = or1_i + 1;
    }
    var pos_name: i64 = mihi_find_osrelease_key(&or1_buf, or1_len, "NAME=", 5);
    var pos_pretty: i64 = mihi_find_osrelease_key(&or1_buf, or1_len, "PRETTY_NAME=", 12);
    var pos_id: i64 = mihi_find_osrelease_key(&or1_buf, or1_len, "ID=", 3);
    assert_eq(pos_name, 5, "NAME= at file-start matched");
    assert(pos_pretty > pos_name, "PRETTY_NAME= found after NAME=");
    assert(pos_id > pos_pretty, "ID= found after PRETTY_NAME=");

    # Mid-line "PRETTY_NAME=" must be rejected. Use a buffer that has
    # 'X' as the first byte to force the leading-anchor check to fail.
    var or2 = "XPRETTY_NAME=foo\n";
    var or2_buf[32];
    var or2_len: i64 = strlen(or2);
    var or2_i = 0;
    while (or2_i < or2_len) {
        store8(&or2_buf + or2_i, load8(or2 + or2_i));
        or2_i = or2_i + 1;
    }
    var pos_midline: i64 = mihi_find_osrelease_key(&or2_buf, or2_len, "PRETTY_NAME=", 12);
    assert_eq(pos_midline, 0 - 1, "mid-line 'PRETTY_NAME=' rejected");

    # Missing key → -1
    var pos_missing: i64 = mihi_find_osrelease_key(&or1_buf, or1_len, "MISSING=", 8);
    assert_eq(pos_missing, 0 - 1, "missing key → -1");

    # ----- host.cyr — mihi_parse_osrelease_value quoted + bare -----
    # parse_osrelease_value mutates the buffer (writes one NUL). Use
    # fresh buffers per shape so prior tests don't see the mutation.
    test_group("host.cyr — parse_osrelease_value quoted + bare");

    # Quoted: PRETTY_NAME="Arch Linux"
    var vq = "PRETTY_NAME=\"Arch Linux\"\nID=arch\n";
    var vq_buf[64];
    var vq_len: i64 = strlen(vq);
    var vq_i = 0;
    while (vq_i < vq_len) {
        store8(&vq_buf + vq_i, load8(vq + vq_i));
        vq_i = vq_i + 1;
    }
    var vq_start: i64 = mihi_find_osrelease_key(&vq_buf, vq_len, "PRETTY_NAME=", 12);
    var vq_val = mihi_parse_osrelease_value(&vq_buf, vq_len, vq_start);
    assert(vq_val != 0, "quoted value parsed");
    assert_eq(streq(vq_val, "Arch Linux"), 1, "quoted value == 'Arch Linux'");

    # Bare: ID=arch
    var vb = "ID=arch\nNAME=foo\n";
    var vb_buf[32];
    var vb_len: i64 = strlen(vb);
    var vb_i = 0;
    while (vb_i < vb_len) {
        store8(&vb_buf + vb_i, load8(vb + vb_i));
        vb_i = vb_i + 1;
    }
    var vb_start: i64 = mihi_find_osrelease_key(&vb_buf, vb_len, "ID=", 3);
    var vb_val = mihi_parse_osrelease_value(&vb_buf, vb_len, vb_start);
    assert(vb_val != 0, "bare value parsed");
    assert_eq(streq(vb_val, "arch"), 1, "bare value == 'arch'");

    # Empty quoted: PRETTY_NAME=""
    var ve = "PRETTY_NAME=\"\"\nID=foo\n";
    var ve_buf[32];
    var ve_len: i64 = strlen(ve);
    var ve_i = 0;
    while (ve_i < ve_len) {
        store8(&ve_buf + ve_i, load8(ve + ve_i));
        ve_i = ve_i + 1;
    }
    var ve_start: i64 = mihi_find_osrelease_key(&ve_buf, ve_len, "PRETTY_NAME=", 12);
    var ve_val = mihi_parse_osrelease_value(&ve_buf, ve_len, ve_start);
    assert_eq(ve_val, 0, "empty quoted value → null");

    # ----- host.cyr — mihi_distro PRETTY_NAME → ID fallback --------
    # Build a synthetic os-release with only ID=; the probe wrapper
    # walks PRETTY_NAME first, then falls back to ID. This is the only
    # fallback chain in mihi — justified because the spec marks
    # PRETTY_NAME as recommended-not-required, ID as mandatory.
    # (Pure parser path — no /etc/os-release read; we exercise the
    # fallback via the public mihi_distro entry would need to mock the
    # file, so we test the helpers directly here and rely on the
    # real-file test below for end-to-end.)
    test_group("host.cyr — mihi_distro ID fallback (helper composition)");
    var fb = "ID=arch\nNAME=foo\n";
    var fb_buf[32];
    var fb_len: i64 = strlen(fb);
    var fb_i = 0;
    while (fb_i < fb_len) {
        store8(&fb_buf + fb_i, load8(fb + fb_i));
        fb_i = fb_i + 1;
    }
    # PRETTY_NAME absent → -1
    var fb_pretty: i64 = mihi_find_osrelease_key(&fb_buf, fb_len, "PRETTY_NAME=", 12);
    assert_eq(fb_pretty, 0 - 1, "PRETTY_NAME absent in fallback fixture");
    var fb_idpos: i64 = mihi_find_osrelease_key(&fb_buf, fb_len, "ID=", 3);
    var fb_val = mihi_parse_osrelease_value(&fb_buf, fb_len, fb_idpos);
    assert_eq(streq(fb_val, "arch"), 1, "ID fallback yields 'arch'");

    # ----- host.cyr — mihi_distro real /etc/os-release -------------
    test_group("host.cyr — mihi_distro real /etc/os-release");
    var dist_buf[1024];
    var live_dist = mihi_distro(&dist_buf, 1024);
    assert(live_dist != 0, "live /etc/os-release yields a distro string");
    assert(strlen(live_dist) > 0, "live distro string non-empty");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
